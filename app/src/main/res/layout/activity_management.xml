<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:id="@+id/managementLayout">


    <RelativeLayout
        android:id="@+id/tableLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_height" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/table1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_height" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/table2"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_height" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/table1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_width" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/table4"
            android:layout_toRightOf="@id/table1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_width" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/table5"
            android:layout_toRightOf="@id/table2"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_width" />

        <smu.ai.waiting.TableWithCircles
            android:id="@+id/table7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/table6"
            android:layout_toRightOf="@id/table3"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:onClick="onTableClick"
            android:src="@drawable/table_width" />

    </RelativeLayout>

</LinearLayout>